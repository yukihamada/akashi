# Server secrets (set via `fly secrets set` in production)
BASE_URL=http://localhost:8080
MASTER_SIGNING_SECRET=change-me-long-random
EDIT_TOKEN_SECRET=change-me-long-random

# Solana instant anchor (devnet). 32-byte ed25519 seed as hex. Leave empty to disable.
# Generate: openssl rand -hex 32  — then fund the printed pubkey on devnet.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_SECRET=
